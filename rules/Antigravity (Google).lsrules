{
  "description" : "Google Antigravity is a next-generation integrated development environment (IDE).",
  "name" : "Antigravity (Google)",
  "rules" : [
    {
      "action" : "allow",
      "ports" : "53",
      "priority": "high",
      "process" : "identifier.EQHXZ8M8AV\/com.google.antigravity",
