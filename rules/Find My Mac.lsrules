{
  "description" : "Find your Apple devices like iPhone, Apple Watch, AirPods and more with Find My.",
  "name" : "Find My",
  "rules" : [
    {
      "action" : "allow",
      "process" : "\/usr\/libexec\/findmydeviced",
      "remote-domains" : "icloud.com"
    },
    {
      "action" : "allow",
      "process" : "identifier.APPLE\/com.apple.findmy",
      "remote" : "any"
    }
  ]
}
